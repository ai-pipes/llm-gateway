# gateway.yaml.example — copy to gateway.yaml and fill in your values

gateway:
  host: "0.0.0.0"
  port: 8080

# Auth: provide your own BaseAuthProvider implementation
# StaticKeyAuthProvider is for quick-start and tests only — not for production
auth:
  module: "gateway.infrastructure.auth.static_key.StaticKeyAuthProvider"
  config:
    keys:
      # Use an environment variable instead of hardcoding the key:
      # "${GATEWAY_KEY_DEV}":
      "sk-change-me":
        user_id: "dev"
        team_id: "engineering"

# Adapters: at least one must be marked as default
adapters:
  # Option 1: any OpenAI-compatible endpoint (no code needed, config only)
  - name: openai
    type: openai_compatible
    base_url: "https://api.openai.com/v1"
    auth:
      token_env: OPENAI_API_KEY   # read from environment variable
    # include_stream_usage: true   # set false for providers that reject stream_options (Ollama, LM Studio, etc.)
    default: true

  # Option 2: custom adapter (Python class)
  # - name: corp-llm
  #   type: plugin
  #   module: "my_adapters.corp_llm.CorpLLMAdapter"

sanitizers:
  input:
    # Option A: NLP-based PII detection via spaCy + Microsoft Presidio (higher recall)
    # Requires: pip install -e ".[presidio]" && python -m spacy download en_core_web_lg
    - module: "gateway.infrastructure.sanitizers.presidio_sanitizer.PresidioSanitizer"
      config:
        language: en

    # Option B: regex-based PII detection — no extra dependencies
    # - module: "gateway.infrastructure.sanitizers.pii_regex.PiiRegexSanitizer"
    #   config:
    #     mode: replace   # replace → placeholder | block → 400

  output: []

audit:
  type: stdout   # stdout | file | plugin
  body_logging:
    enabled: false   # set true for compliance logging (logs full messages + completion)

# File backend — writes JSON lines to a local file:
# audit:
#   type: file
#   path: "/var/log/gateway/audit.jsonl"
#   body_logging:
#     enabled: true

# Plugin backend — custom backend (Python class):
# audit:
#   type: plugin
#   module: "my_backends.corp_audit.CorpAuditBackend"
#   config:
#     endpoint: "https://audit.corp.internal"
#     token_env: AUDIT_TOKEN
