# gateway.yaml.example — скопируй в gateway.yaml и заполни своими значениями

gateway:
  host: "0.0.0.0"
  port: 8080

# Auth: укажи свою реализацию BaseAuthProvider
# StaticKeyAuthProvider — только для быстрого старта, не для production
auth:
  module: "gateway.middleware.auth.StaticKeyAuthProvider"
  config:
    keys:
      # Используй переменную окружения вместо хардкода ключа:
      # "${GATEWAY_KEY_DEV}":
      "sk-change-me":
        user_id: "dev"
        team_id: "engineering"

# Адаптеры: один обязательный default
adapters:
  # Вариант 1: любой OpenAI-compatible endpoint (нет кода, только конфиг)
  - name: openai
    type: openai_compatible
    base_url: "https://api.openai.com/v1"
    auth:
      token_env: OPENAI_API_KEY   # читается из переменной окружения
    default: true

  # Вариант 2: свой адаптер (Python-класс)
  # - name: corp-llm
  #   type: plugin
  #   module: "my_adapters.corp_llm.CorpLLMAdapter"

sanitizers:
  input:
    - module: "gateway.sanitizers.pii_regex.PiiRegexSanitizer"
      config:
        mode: replace   # replace → [EMAIL]/[PHONE]/[CARD] | block → 400
  output: []

audit:
  type: stdout   # JSON lines → stdout → ELK/Splunk/etc

# File backend — writes JSON lines to a local file:
# audit:
#   type: file
#   path: "/var/log/gateway/audit.jsonl"

# Plugin backend — custom backend (Python class):
# audit:
#   type: plugin
#   module: "my_backends.corp_audit.CorpAuditBackend"
#   config:
#     endpoint: "https://audit.corp.internal"
#     token_env: AUDIT_TOKEN
