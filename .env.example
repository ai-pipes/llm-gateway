# Copy to .env and fill in your values
# This file is checked in to git — .env is not.

# API key for the default OpenAI adapter (referenced as token_env: OPENAI_API_KEY in gateway.yaml)
OPENAI_API_KEY=sk-...

# Add keys for other adapters here, e.g.:
# ANTHROPIC_API_KEY=...
# AZURE_OPENAI_API_KEY=...
